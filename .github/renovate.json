{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeStrategy": "squash",
  "schedule": ["* * 2-31 * *"],
  "packageRules": [
    {
      "matchPackageNames": [
        "com.android.tools.build:gradle"
      ],
      "ignorePaths": [
        "stem-plugin/*"
      ]
    }
  ]
}
